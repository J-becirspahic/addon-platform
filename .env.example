# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/addon_platform?schema=public"

# API Server
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-access-token-secret-here
JWT_REFRESH_SECRET=your-refresh-token-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GitHub App
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret
GITHUB_APP_CLIENT_ID=your-client-id
GITHUB_APP_CLIENT_SECRET=your-client-secret
GITHUB_APP_INSTALLATION_ID=your-installation-id

# GitHub Organization
GITHUB_ORG_NAME=addons
REVIEW_TEAM_SLUG=reviewers

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=your-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Builder Service
BUILDER_URL=http://localhost:3002
BUILD_CALLBACK_SECRET=your-build-callback-secret-here

# S3/MinIO (for build artifacts)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=addon-artifacts
S3_REGION=us-east-1

# Access Reconciliation Schedule (cron expression, default: hourly)
RECONCILIATION_CRON=0 * * * *

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
