{
  "name": "addon-platform",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @addon-platform/api dev",
    "dev:web": "pnpm --filter @addon-platform/web dev",
    "dev:builder": "pnpm --filter @addon-platform/builder dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @addon-platform/api build",
    "build:web": "pnpm --filter @addon-platform/web build",
    "build:builder": "pnpm --filter @addon-platform/builder build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @addon-platform/api prisma generate",
    "db:migrate": "pnpm --filter @addon-platform/api prisma migrate dev",
    "db:push": "pnpm --filter @addon-platform/api prisma db push",
    "db:seed": "pnpm --filter @addon-platform/api prisma db seed",
    "db:studio": "pnpm --filter @addon-platform/api prisma studio"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
